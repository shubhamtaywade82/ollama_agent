#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

require "thor"
require "trading_agent"
require "dotenv/load"

module TradingAgent
  class CLI < Thor
    desc "start", "Start the autonomous trading agent"
    method_option :symbol, type: :string, default: "BTCUSDT", desc: "Symbol to trade"
    method_option :model, type: :string, desc: "Ollama model name (defaults to OLLAMA_AGENT_MODEL or qwen2.5:14b)"
    method_option :testnet, type: :boolean, default: true, desc: "Use Binance Testnet"
    method_option :confirm, type: :boolean, default: false, aliases: "-c", desc: "Prompt to confirm trade execution"
    def start
      SemanticLogger.add_appender(io: $stdout, formatter: :color)
      SemanticLogger.default_level = :info

      exchange = TradingAgent::Exchanges::BinanceSpot.new(
        api_key: ENV["BINANCE_API_KEY"],
        secret_key: ENV["BINANCE_SECRET_KEY"],
        testnet: options[:testnet]
      )

      model_name = options[:model] || ENV["OLLAMA_AGENT_MODEL"] || ENV["OLLAMA_MODEL"] || ENV["MODEL"] || "qwen2.5:14b"

      runner = TradingAgent::Runner.new(
        exchange: exchange,
        model: model_name,
        symbols: [options[:symbol]],
        confirm: options[:confirm]
      )

      runner.start
    end

    desc "chat", "Start the interactive trading chat shell"
    method_option :model, type: :string, desc: "Ollama model name (defaults to OLLAMA_AGENT_MODEL, OLLAMA_MODEL, MODEL, or qwen2.5:14b)"
    method_option :testnet, type: :boolean, default: true, desc: "Use Binance Testnet"
    def chat
      exchange = TradingAgent::Exchanges::BinanceSpot.new(
        api_key: ENV["BINANCE_API_KEY"],
        secret_key: ENV["BINANCE_SECRET_KEY"],
        testnet: options[:testnet]
      )

      model_name = options[:model] || ENV["OLLAMA_AGENT_MODEL"] || ENV["OLLAMA_MODEL"] || ENV["MODEL"] || "qwen2.5:14b"
      state = TradingAgent::Market::State.new
      orchestrator = TradingAgent::Llm::Orchestrator.new(state, exchange, model: model_name)

      shell = TradingAgent::InteractiveShell.new(state, exchange, orchestrator)
      shell.start
    end

    desc "version", "Print the version"
    def version
      puts "TradingAgent v#{TradingAgent::VERSION}"
    end
  end
end

TradingAgent::CLI.start(ARGV)
